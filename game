<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Oyun Kütüphanem</title>
    <style>
        :root {
            --bg-color: #0b0c10;
            --card-bg: #1f2833;
            --text-color: #c5a059;
            --text-muted: #95a5a6;
            --accent-color: #45f3ff;
            --pink-accent: #ff75a0;
            --danger-color: #ff4d4d;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: #ffffff;
            transition: background-color 0.5s ease;
            min-height: 100vh;
            padding-bottom: 50px;
        }

        body.chill-mode {
            --bg-color: #1a0f1a;
            --card-bg: #2d1b2d;
            --accent-color: var(--pink-accent);
        }

        /* Header & Nav */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 40px;
            background-color: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .tabs {
            display: flex;
            gap: 20px;
        }

        .tab-btn {
            font-size: 24px;
            font-weight: bold;
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            transition: all 0.3s ease;
            padding: 5px 10px;
            position: relative;
        }

        .tab-btn.active {
            color: var(--accent-color);
        }

        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 100%;
            height: 3px;
            background-color: var(--accent-color);
            border-radius: 2px;
        }

        .right-menu {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .btn {
            background-color: var(--card-bg);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn:hover {
            border-color: var(--accent-color);
            background-color: rgba(255,255,255,0.05);
        }

        .add-btn {
            font-size: 24px;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--accent-color);
            color: #000;
            font-weight: bold;
            border: none;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .add-btn:hover {
            transform: scale(1.1);
        }

        /* Game Grid */
        .container {
            max-width: 1400px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .game-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 30px;
        }

        .game-card {
            background-color: var(--card-bg);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
            position: relative;
            transition: transform 0.3s, box-shadow 0.3s;
            display: flex;
            flex-direction: column;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .game-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.5);
            border-color: rgba(255,255,255,0.15);
        }

        .image-container {
            width: 100%;
            height: 160px;
            background-color: #111;
            position: relative;
        }

        .game-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .placeholder-img {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: var(--text-muted);
            font-style: italic;
            font-size: 14px;
            background: linear-gradient(45deg, #111, #222);
        }

        .heart-badge {
            position: absolute;
            top: 10px;
            left: 10px;
            background: rgba(0,0,0,0.7);
            padding: 5px 8px;
            border-radius: 20px;
            font-size: 16px;
            backdrop-filter: blur(5px);
        }

        .card-content {
            padding: 15px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
            justify-content: space-between;
        }

        .game-title {
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 8px;
            color: #fff;
        }

        .game-desc {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 12px;
            line-height: 1.4;
        }

        .game-meta {
            font-size: 12px;
            color: var(--accent-color);
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
        }

        .tag-container {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 15px;
        }

        .tag {
            font-size: 11px;
            padding: 3px 8px;
            border-radius: 4px;
            font-weight: 600;
            text-transform: uppercase;
        }

        /* Dinamik Renkli Etiket Renkleri */
        .tag-anomali { background-color: #8e44ad; color: white; }
        .tag-korku { background-color: #c0392b; color: white; }
        .tag-bulmaca { background-color: #2980b9; color: white; }
        .tag-japon { background-color: #d35400; color: white; }
        .tag-üretim { background-color: #27ae60; color: white; }
        .tag-tıklama { background-color: #16a085; color: white; }
        .tag-ev { background-color: #f39c12; color: #000; }
        .tag-varsayilan { background-color: #7f8c8d; color: white; }

        .card-actions {
            display: flex;
            justify-content: flex-end;
            margin-top: auto;
        }

        .delete-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 14px;
            transition: color 0.2s;
        }

        .delete-btn:hover {
            color: var(--danger-color);
        }

        /* Modal / Form */
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-color: rgba(0,0,0,0.8);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(5px);
        }

        .modal-content {
            background-color: #151a21;
            padding: 30px;
            border-radius: 12px;
            width: 100%;
            max-width: 500px;
            border: 1px solid rgba(255,255,255,0.1);
            position: relative;
        }

        .close-modal {
            position: absolute;
            top: 15px; right: 15px;
            font-size: 24px;
            cursor: pointer;
            color: var(--text-muted);
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            font-size: 14px;
            margin-bottom: 5px;
            color: var(--text-muted);
        }

        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 10px;
            background-color: #0b0c10;
            border: 1px solid rgba(255,255,255,0.1);
            color: white;
            border-radius: 6px;
        }

        .form-group input:focus {
            border-color: var(--accent-color);
            outline: none;
        }

        .hidden-file-input {
            display: none;
        }
    </style>
</head>
<body>

    <header>
        <div class="tabs">
            <button class="tab-btn active" id="horror-tab" onclick="switchTab('horror')">KORKU</button>
            <button class="tab-btn" id="chill-tab" onclick="switchTab('chill')">CHILL</button>
        </div>
        <div class="right-menu">
            <button class="btn" onclick="exportToJS()">JS Dışa Aktar</button>
            <button class="btn" onclick="exportToManifest()">Manifest Dışa Aktar</button>
            <button class="btn" onclick="document.getElementById('import-file').click()">İçe Aktar</button>
            <input type="file" id="import-file" class="hidden-file-input" accept=".json,.txt,.js" onchange="importData(event)">
            <button class="add-btn" onclick="openModal()">+</button>
        </div>
    </header>

    <div class="container">
        <div class="game-grid" id="game-container"></div>
    </div>

    <div class="modal" id="add-modal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeModal()">&times;</span>
            <h3 style="margin-bottom: 20px;">Yeni Oyun Ekle</h3>
            <form id="game-form" onsubmit="addGame(event)">
                <div class="form-group">
                    <label>Kategori</label>
                    <select id="form-category" required>
                        <option value="horror">Korku</option>
                        <option value="chill">Chill</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Oyun Adı</label>
                    <input type="text" id="form-name" required>
                </div>
                <div class="form-group">
                    <label>Resim Linki (URL)</label>
                    <input type="url" id="form-image">
                </div>
                <div class="form-group">
                    <label>Yıl</label>
                    <input type="number" id="form-year" placeholder="Örn: 2026">
                </div>
                <div class="form-group">
                    <label>Süre / Oynanış Süresi</label>
                    <input type="text" id="form-time" placeholder="Örn: 2 saat veya 20-30 Saat" required>
                </div>
                <div class="form-group">
                    <label>Etiketler (Virgülle ayırın)</label>
                    <input type="text" id="form-tags" placeholder="anomali, korku, bulmaca">
                </div>
                <div class="form-group" id="desc-group" style="display:none;">
                    <label>Açıklama (Chill Oyunlar İçin)</label>
                    <textarea id="form-desc" rows="2"></textarea>
                </div>
                <div class="form-group" style="display: flex; gap: 10px; align-items: center; margin-top: 10px;">
                    <input type="checkbox" id="form-favorite" style="width: auto;">
                    <label for="form-favorite" style="margin-bottom: 0; cursor: pointer;">Favorilere Ekle (Kalp Emojisi ❤️)</label>
                </div>
                <button type="submit" class="btn" style="width:100%; background-color: var(--accent-color); color:#000; font-weight:bold; margin-top:15px;">Kaydet</button>
            </form>
        </div>
    </div>

