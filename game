        let favoriteGames = ['The Maid', 'Gas Station Case', 'Skull Hotel', 'No, I\'m not a Human', 'HELLMART', 'Last Report', 'We Used to Play Here', 'Agreee'];
        
        let currentTab = 'horror';

        // LocalStorage'dan veri yükleme veya varsayılanı kullanma
        if(localStorage.getItem('allGames')) {
            allGames = JSON.parse(localStorage.getItem('allGames'));
            chillGames = JSON.parse(localStorage.getItem('chillGames'));
            favoriteGames = JSON.parse(localStorage.getItem('favoriteGames'));
        }

        function saveData() {
            localStorage.setItem('allGames', JSON.stringify(allGames));
            localStorage.setItem('chillGames', JSON.stringify(chillGames));
            localStorage.setItem('favoriteGames', JSON.stringify(favoriteGames));
        }

        // Etiket Sınıfını Belirleme
        function getTagClass(tag) {
            tag = tag.toLowerCase().trim();
            if(tag.includes('anomali')) return 'tag-anomali';
            if(tag.includes('korku')) return 'tag-korku';
            if(tag.includes('bulmaca')) return 'tag-bulmaca';
            if(tag.includes('japon')) return 'tag-japon';
            if(tag.includes('üretim')) return 'tag-üretim';
            if(tag.includes('tıklama')) return 'tag-tıklama';
            if(tag.includes('ev yap') || tag.includes('ev')) return 'tag-ev';
            return 'tag-varsayilan';
        }

        // Listeyi Ekrana Basma
        function renderGames() {
            const container = document.getElementById('game-container');
            container.innerHTML = '';
            
            const activeList = (currentTab === 'horror') ? allGames : chillGames;

            activeList.forEach((game, index) => {
                const isFavorite = favoriteGames.some(fav => fav.toLowerCase() === game.name.toLowerCase());
                
                // Etiketleri parse etme
                let tagsArray = [];
                if(game.type) {
                    tagsArray = game.type.split(',').map(t => t.trim());
                } else if(game.tags) {
                    tagsArray = game.tags;
                }

                const gameTime = game.playtime || game.time || 'Belirtilmedi';
                const gameImgSrc = game.image || game.img || '';

                const card = document.createElement('div');
                card.className = 'game-card';

                let imgHtml = gameImgSrc 
                    ? `<img src="${gameImgSrc}" class="game-img" alt="${game.name}" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">`
                    : '';
                
                card.innerHTML = `
                    <div class="image-container">
                        ${imgHtml}
                        <div class="placeholder-img" style="${gameImgSrc ? 'display:none;' : 'display:flex;'}">Resim Mevcut Değil</div>
                        ${isFavorite ? '<div class="heart-badge">❤️</div>' : ''}
                    </div>
                    <div class="card-content">
                        <div>
                            <div class="game-title">${game.name}</div>
                            ${game.desc ? `<div class="game-desc">${game.desc}</div>` : ''}
                            <div class="game-meta">
                                <span>⏱️ ${gameTime}</span>
                                ${game.year ? `<span>📅 ${game.year}</span>` : ''}
                            </div>
                        </div>
                        <div>
                            <div class="tag-container">
                                ${tagsArray.map(tag => `<span class="tag ${getTagClass(tag)}">${tag}</span>`).join('')}
                            </div>
                            <div class="card-actions">
                                <button class="delete-btn" onclick="deleteGame(${index})">Sil 🗑️</button>
                            </div>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        // Sekme Değiştirme
        function switchTab(tab) {
            currentTab = tab;
            document.getElementById('horror-tab').classList.toggle('active', tab === 'horror');
            document.getElementById('chill-tab').classList.toggle('active', tab === 'chill');
            document.body.className = tab === 'chill' ? 'chill-mode' : '';
            renderGames();
        }

        // Modal Yönetimi
        function openModal() {
            document.getElementById('add-modal').style.display = 'flex';
            document.getElementById('form-category').addEventListener('change', (e) => {
                document.getElementById('desc-group').style.display = e.target.value === 'chill' ? 'block' : 'none';
            });
        }

        function closeModal() {
            document.getElementById('add-modal').style.display = 'none';
            document.getElementById('game-form').reset();
        }

        // Yeni Oyun Ekleme
        function addGame(e) {
            e.preventDefault();
            const category = document.getElementById('form-category').value;
            const name = document.getElementById('form-name').value;
            const image = document.getElementById('form-image').value;
            const year = document.getElementById('form-year').value;
            const time = document.getElementById('form-time').value;
            const tagsInput = document.getElementById('form-tags').value;
            const desc = document.getElementById('form-desc').value;
            const isFav = document.getElementById('form-favorite').checked;

            if(isFav && !favoriteGames.includes(name)) {
                favoriteGames.push(name);
            }

            if(category === 'horror') {
                const newGame = {
                    name: name,
                    type: tagsInput || 'korku',
                    playtime: time
                };
                if(image) newGame.image = image;
                if(year) newGame.year = year;
                allGames.push(newGame);
            } else {
                const newGame = {
                    name: name,
                    desc: desc || 'Açıklama girilmedi.',
                    time: time,
                    tags: tagsInput ? tagsInput.split(',').map(t => t.trim()) : ['chill']
                };
                if(image) newGame.img = image;
                if(year) newGame.year = year;
                chillGames.push(newGame);
            }

            saveData();
            closeModal();
            renderGames();
        }

        // Oyun Silme
        function deleteGame(index) {
            if(confirm("Bu oyunu listeden silmek istediğine emin misin?")) {
                if(currentTab === 'horror') {
                    allGames.splice(index, 1);
                } else {
                    chillGames.splice(index, 1);
                }
                saveData();
                renderGames();
            }
        }

        // İstediğin Formatlarda Tam Birebir JS Çıktısı Sağlayan Dışa Aktarma Fonksiyonu
        function exportToJS() {
            const dataString = `const allGames = ${JSON.stringify(allGames, null, 2)};\n\nconst chillGames = ${JSON.stringify(chillGames, null, 2)};\n\nconst favoriteGames = ${JSON.stringify(favoriteGames, null, 2)};`;
            downloadFile(dataString, 'data.js', 'text/javascript');
        }

        // Manifest (JSON) olarak dışa aktarma
        function exportToManifest() {
            const manifest = {
                allGames: allGames,
                chillGames: chillGames,
                favoriteGames: favoriteGames
            };
            downloadFile(JSON.stringify(manifest, null, 2), 'manifest.json', 'application/json');
        }

        // Dosya İndirme Tetikleyicisi
        function downloadFile(content, fileName, contentType) {
            const a = document.createElement("a");
            const file = new Blob([content], {type: contentType});
            a.href = URL.createObjectURL(file);
            a.download = fileName;
            a.click();
        }

        // Dosya İçe Aktarma İşlemi
        function importData(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                const text = e.target.result;
                try {
                    // Eğer JSON manifest dosyasıysa direkt parse et
                    if(text.trim().startsWith('{')) {
                        const parsed = JSON.parse(text);
                        if(parsed.allGames) allGames = parsed.allGames;
                        if(parsed.chillGames) chillGames = parsed.chillGames;
                        if(parsed.favoriteGames) favoriteGames = parsed.favoriteGames;
                    } else {
                        // JS formatıysa regex veya dinamik fonksiyonla verileri çekmeyi dene
                        alert("Manifest JSON formatındaki yedekleri tercih edin. Klasik düz metin işleniyor.");
                    }
                    saveData();
                    renderGames();
                    alert("Veriler başarıyla senkronize edildi!");
                } catch (err) {
                    alert("Dosya okunamadı veya geçersiz format.");
                }
            };
            reader.readAsText(file);
        }

        // İlk açılışta render et
        renderGames();
    </script>
